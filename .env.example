# ── Claude / Anthropic ────────────────────────────────────────────────
# The only LLM provider Exempclaw uses. Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Default model for agents. Override per-agent in the agent config.
# Options: claude-opus-4-8 (default), claude-fable-5, claude-sonnet-4-6, claude-haiku-4-5
EXEMPCLAW_MODEL=claude-opus-4-8

# ── Runtime ───────────────────────────────────────────────────────────
# Where agent state (memory, context, transcripts) is persisted.
EXEMPCLAW_DATA_DIR=./data

# log level: debug | info | warn | error
EXEMPCLAW_LOG_LEVEL=info

# Global default for outward actions (send email, post to Slack, push to GitHub).
# "ask"   – require human approval in the terminal before each outward action
# "auto"  – execute without prompting (use only once you trust an agent)
# "deny"  – block all outward actions (dry-run / shadow mode)
EXEMPCLAW_ACTION_POLICY=ask

# ── Connector credentials (fill in only the ones you use) ─────────────
# Email (IMAP receive + SMTP send)
EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=

# Slack (bot token, app token for socket mode)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# Notion (internal integration token)
NOTION_TOKEN=

# GitHub (fine-grained PAT)
GITHUB_TOKEN=
