# ── Claude / Anthropic ────────────────────────────────────────────────
# The only LLM provider Exempclaw uses. Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Default model for agents. Override per-agent in the agent config.
# Options: claude-opus-4-8 (default), claude-fable-5, claude-sonnet-4-6, claude-haiku-4-5
EXEMPCLAW_MODEL=claude-opus-4-8

# ── Runtime ───────────────────────────────────────────────────────────
# Where agent state (memory, history, run records) is persisted.
EXEMPCLAW_DATA_DIR=./data

# log level: debug | info | warn | error
EXEMPCLAW_LOG_LEVEL=info

# Global default for outward actions (send email, post to Slack, comment on GitHub).
# "ask"   – require human approval in the terminal before each outward action
# "auto"  – execute without prompting (use only once you trust an agent)
# "deny"  – block all outward actions (dry-run / shadow mode)
# Per-tool overrides live in the agent config ("toolPolicies").
EXEMPCLAW_ACTION_POLICY=ask

# Compact an agent's conversation history once its prompt exceeds this many
# tokens (older turns are summarized, recent turns kept verbatim).
EXEMPCLAW_CONTEXT_BUDGET_TOKENS=200000

# Set to any value to disable terminal animations (they also auto-disable
# when output is piped or NO_COLOR is set).
# EXEMPCLAW_NO_ANIM=1

# ── Connector credentials (fill in only the ones you use) ─────────────
# See docs/CONNECTORS.md for how to provision each of these.

# Email — IMAP (read + inbound events) and SMTP (send). For Gmail/Workspace
# use an app password. EMAIL_FROM defaults to EMAIL_USER.
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_FROM=

# Slack — bot token (xoxb-…) for tools; app-level token (xapp-…) with Socket
# Mode enabled for inbound mentions/DMs.
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# Notion — internal integration secret. Share the relevant pages with the
# integration or searches come back empty.
NOTION_TOKEN=

# GitHub — fine-grained PAT with Issues read/write on the target repos.
# GITHUB_REPOS enables inbound polling, e.g. "acme/app,acme/infra".
GITHUB_TOKEN=
GITHUB_REPOS=
GITHUB_POLL_SECONDS=60
