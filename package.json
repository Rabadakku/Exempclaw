{
  "name": "exempclaw",
  "version": "0.1.0",
  "description": "A terminal-based framework for building and running many Claude-powered agents that take over a departed employee's role, building context from their past work and acting through their channels with a new persona.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "exempclaw": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --import tsx ./src/**/*.test.ts"
  },
  "keywords": [
    "claude",
    "anthropic",
    "agents",
    "automation",
    "cli"
  ],
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@anthropic-ai/sdk": "^0.69.0",
    "commander": "^14.0.1",
    "dotenv": "^17.2.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.20.1",
    "typescript": "^5.9.3"
  }
}
