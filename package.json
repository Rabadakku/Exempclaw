{
  "name": "exempclaw",
  "version": "0.3.0",
  "description": "A terminal-based framework for building and running many Claude-powered agents that take over a departed employee's role, building context from their past work and acting through their channels with a new persona.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "exempclaw": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --import tsx \"src/**/*.test.ts\" \"src/**/*.test.tsx\""
  },
  "keywords": [
    "claude",
    "anthropic",
    "agents",
    "automation",
    "cli"
  ],
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "commander": "^14.0.1",
    "dotenv": "^17.2.3",
    "imapflow": "^1.4.0",
    "ink": "^7.0.6",
    "ink-text-input": "^6.0.0",
    "mailparser": "^3.9.9",
    "nodemailer": "^8.0.11",
    "react": "^19.2.7",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/mailparser": "^3.4.6",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^7.0.4",
    "@types/react": "^19.2.17",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.20.1",
    "typescript": "^5.9.3"
  }
}
